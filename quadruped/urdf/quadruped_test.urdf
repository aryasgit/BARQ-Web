    </visual>
  </link>

  <joint name="fl_coxa_to_fl_thigh" type="revolute">
    <parent link="fl_coxa"/>
    <child link="fl_thigh"/>
    <origin xyz="-0.026910 0.025690 -0.010752" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="fl_thigh">
    <visual>
      <origin xyz="-0.103344 -0.066999 -0.208214" rpy="0 0 0"/>
