<?xml version="1.0"?>
<robot name="quadruped">

  <!-- ================= BASE ================= -->
  <link name="base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="D:/quadruped_robot/robot_description/meshes/base/base.dae"/>
      </geometry>
    </visual>
  </link>

  <!-- ================= FRONT LEFT ================= -->
  <joint name="base_to_fl_coxa" type="revolute">
    <parent link="base"/>
    <child link="fl_coxa"/>
    <origin xyz="0.130254 0.041309 0.218966" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
  </joint>

  <link name="fl_coxa">
    <visual>
      <origin xyz="-0.130254 -0.041309 -0.218966" rpy="0 0 0"/>
      <geometry>
        <mesh filename="D:/quadruped_robot/robot_description/meshes/fl/fl_coxa.dae"/>
