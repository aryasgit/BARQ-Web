    <axis xyz="0 1 0"/>
  </joint>

  <link name="fl_wrist">
    <visual>
      <!-- inverse of FL wrist world origin -->
      <origin xyz="-0.045648 -0.074999 -0.117518" rpy="0 0 0"/>
      <geometry>
        <mesh filename="D:/quadruped_robot/robot_description/meshes/fl/fl_wrist.dae"/>
      </geometry>
    </visual>
  </link>

  <!-- ================= FRONT RIGHT ================= -->
  <joint name="base_to_fr_coxa" type="revolute">
